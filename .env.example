# .env.example
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# -----------------------------------------------
# SUPABASE — required for everything
# Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------

# Your Supabase project URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe to expose to browser, limited by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your Supabase service role key (NEVER expose to browser — server-side only)
# Get from: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# -----------------------------------------------
# APP CONFIG — optional, has defaults in /lib/config.ts
# -----------------------------------------------

# Display name of the store (shown in nav and on invoices)
NEXT_PUBLIC_STORE_NAME=Lumato Hardware

# Currency code (e.g. TZS, USD, KES)
NEXT_PUBLIC_CURRENCY=TZS

# Currency symbol shown next to prices
NEXT_PUBLIC_CURRENCY_SYMBOL=TSh


# -----------------------------------------------
# TESTING — only needed to run automated tests
# -----------------------------------------------

# Same as NEXT_PUBLIC_SUPABASE_URL — used by Playwright and test scripts
TEST_SUPABASE_URL=https://your-project-id.supabase.co

# Use the service role key for tests so they can bypass RLS and clean up test data
TEST_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
